# Port API (défaut : 3000)
PORT=3000

# PostgreSQL Supabase — Project Settings → Database → Connection string (pooler)
DATABASE_URL=postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres

# Optionnel — Supabase (health check)
SUPABASE_URL=https://[PROJECT].supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Origines front supplémentaires (séparées par des virgules)
# CORS_ORIGINS=http://localhost:8080

# URL du frontend (liens de vérification email)
FRONTEND_URL=https://stageflow-9775.onrender.com

# Envoi d'emails (SMTP) — optionnel en dev (lien affiché dans les logs API)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=StageFlow <noreply@stageflow.local>

# Durée de validité du lien de vérification (heures)
# EMAIL_VERIFY_TTL_HOURS=24
