{
  "info": {
    "name": "StageFlow - Architecture Multi-Facultés",
    "description": "Collection d'endpoints pour tester la hiérarchie Université → Faculté → Département",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "🔐 AUTH",
      "item": [
        {
          "name": "Login - Admin Université",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@univ-bejaia.dz\",\n  \"password\": \"admin123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login - Admin Faculté",
          "request": {
            "method": "POST",
            "header": [
              {
