              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin.fshs@univ-bejaia.dz\",\n  \"password\": \"faculty123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
